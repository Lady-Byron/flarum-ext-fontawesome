{
  "extends": "flarum-tsconfig",
  "include": [
    "src/**/*",
    "../vendor/flarum/core/js/dist-typings/**/*.d.ts",  // <— 加：不只 @types，整套 d.ts
    "@types/**/*"
  ],
  "compilerOptions": {
    "declarationDir": "./dist-typings",
    "baseUrl": ".",
    "paths": {
      "flarum/*": ["../vendor/flarum/core/js/dist-typings/*"]
    },

    // 建议追加（覆盖 flarum-tsconfig 的默认）：
    "skipLibCheck": true,
    "moduleResolution": "Node"
  }
}
